<UserControl x:Class="WPF_Project_1.View.UserControl.TunerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPF_Project_1.View.UserControl"
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="Transparent">

        <Grid Grid.Column="1" Background="Transparent" Grid.IsSharedSizeScope="True">
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6*"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding CurrentFrequency, StringFormat={}{0} Гц}" Height="50px" Width="200px"
                HorizontalAlignment="right" VerticalAlignment="top" FontSize="20"
                Background="gray"/>

            <Grid VerticalAlignment="center" Width="480">
                    <Grid.RowDefinitions >
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                    <TextBlock Text="{Binding CurrentNoteName}" FontSize="72" FontWeight="Bold" Foreground="black" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TargetFrequency}" FontSize="16" Foreground="#8a8a93" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Grid Grid.Row="1" VerticalAlignment="Center" Margin="20,0">
                    <Rectangle Height="4" Fill="#7d7d7d" RadiusX="2" RadiusY="2" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                        <Rectangle Grid.Column="0" Width="2" Height="15" Fill="#1a1a1a" HorizontalAlignment="Left"/>
                        <Rectangle Grid.Column="2" Width="4" Height="25" Fill="lightgreen" />
                        <Rectangle Grid.Column="4" Width="2" Height="15" Fill="#1a1a1a" HorizontalAlignment="Right"/>
                        </Grid>

                    <Border Width="16" Height="34" Background="red" CornerRadius="4" 
                        HorizontalAlignment="Center" >
                            <Border.Effect>
                                <DropShadowEffect Color="red" BlurRadius="15" ShadowDepth="0"/>
                            </Border.Effect>
                        <Border.RenderTransform>
                            <TranslateTransform X="{Binding SliderPosition}" />
                        </Border.RenderTransform>
                    </Border>

                    </Grid>

                <TextBlock Grid.Row="2" Style="{StaticResource SoundStatusTextBlockStyle}"
               HorizontalAlignment="Center" Margin="0,20,0,0"/>
                
                </Grid>

                <Grid Height="400" Width="256"  HorizontalAlignment="center"
                  Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="6*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.2*"/>
                    <RowDefinition Height="2.5*"/>
                    <RowDefinition Height="2.5*"/>
                    <RowDefinition Height="2.5*"/>
                    <RowDefinition Height="3*"/>
                </Grid.RowDefinitions>

                <RadioButton Grid.Row="1"
                         Style="{StaticResource GuitarStringButton}" 
                         Panel.ZIndex="1" RenderTransformOrigin="0.5,0.5"
                    Margin="3,0,14,0"  Foreground="white"
                    Checked="AnyButton_Checked" Tag="Ре(D)"
                    GroupName="Strings" Content="4 (D3)"
                    Command="{Binding SelectStringCommand}" 
                    CommandParameter="D3|146.83">

                    <RadioButton.RenderTransform>
                        <TransformGroup>
                            <RotateTransform Angle="180"/>
                        </TransformGroup>
                    </RadioButton.RenderTransform>
                </RadioButton>

                <RadioButton  Grid.Row="2" 
                         Style="{StaticResource GuitarStringButton}" 
                         Panel.ZIndex="1"  RenderTransformOrigin="0.5,0.5" Margin="6,0,11,0" 
                          Checked="AnyButton_Checked" Tag="Ля(A)"
                          GroupName="Strings" Content="5 (A2)"
                          Command="{Binding SelectStringCommand}" 
                          CommandParameter="A2|110.00">
                    <RadioButton.RenderTransform>
                        <TransformGroup>
                            <RotateTransform Angle="180"/>
                        </TransformGroup>
                    </RadioButton.RenderTransform>
                </RadioButton>
                
                <RadioButton  Grid.Row="3" 
                         Style="{StaticResource GuitarStringButton}" 
                         Panel.ZIndex="1"  RenderTransformOrigin="0.5,0.5" Margin="9,0,8,0" 
                         Checked="AnyButton_Checked" Tag="Мі(E)"
                         GroupName="Strings" Content="6 (E2)" 
                         Command="{Binding SelectStringCommand}" 
                         CommandParameter="E2|82.41">
                    <RadioButton.RenderTransform>
                        <TransformGroup>
                            <RotateTransform Angle="180"/>
                        </TransformGroup>
                    </RadioButton.RenderTransform>
                </RadioButton>
                
                <RadioButton Grid.Column="2" 
                        Style="{StaticResource GuitarStringButton}" 
                        Panel.ZIndex="1" Margin="14,0,3,0" Grid.Row="1"  
                             Checked="AnyButton_Checked" Tag="Соль(G)"
                             GroupName="Strings" Content="3 (G3)"
                     Command="{Binding SelectStringCommand}" 
                     CommandParameter="G3|196.00"/>
                
                <RadioButton Grid.Column="2"  Grid.Row="2" 
                        Style="{StaticResource GuitarStringButton}" 
                        Panel.ZIndex="1" Margin="11,0,6,0"   
                             Checked="AnyButton_Checked" Tag="Сі(B)"
                             GroupName="Strings" Content="2 (B3)"
                     Command="{Binding SelectStringCommand}" 
                     CommandParameter="B3|246.94"/>
                <RadioButton Grid.Column="2"  Grid.Row="3" 
                        Style="{StaticResource GuitarStringButton}" 
                        Panel.ZIndex="1" Margin="8,0,9,0"
                             Checked="AnyButton_Checked" Tag="Мі(E)"
                             GroupName="Strings" Content="1 (E4)"
                     Command="{Binding SelectStringCommand}" 
                     CommandParameter="E4|329.63"/>

                <Label Grid.Column="1" Grid.Row="3" Content="6" Panel.ZIndex="1"
                       VerticalAlignment="center" HorizontalAlignment="left"
                       FontSize="25" Foreground="white" Margin="6,0,0,0"/>
                <Label Grid.Column="1" Grid.Row="3" Content="1" Panel.ZIndex="1"
                VerticalAlignment="center" HorizontalAlignment="right"
                FontSize="25" Foreground="white" Margin="0,0,6,0"/>

                <Label Grid.Column="1" Grid.Row="2" Content="5" Panel.ZIndex="1"
                VerticalAlignment="center" HorizontalAlignment="left"
                FontSize="25" Foreground="white" Margin="1,0,0,0"/>
                <Label Grid.Column="1" Grid.Row="2" Content="2" Panel.ZIndex="1"
                VerticalAlignment="center" HorizontalAlignment="right"
                FontSize="25" Foreground="white" Margin="0,0,2,0"/>

                <Label Grid.Column="1" Grid.Row="1" Content="4" Panel.ZIndex="1"
                VerticalAlignment="center" HorizontalAlignment="left"
                FontSize="25" Foreground="white" Margin="-1,10,0,0"/>
                <Label Grid.Column="1" Grid.Row="1" Content="3" Panel.ZIndex="1"
                VerticalAlignment="center" HorizontalAlignment="right"
                FontSize="25" Foreground="white" Margin="0,10,-1,0"/>

                <TextBlock Name="tbStringDisplay" Grid.Column="1"  Panel.ZIndex="1" HorizontalAlignment="Center"
                           VerticalAlignment="center" FontSize="20"/>

                <Image Source="/Assets/Icons/guitar-deck-cutout3.png" Height="auto"
                   Grid.ColumnSpan="3" Grid.RowSpan="10"/>
                    
            </Grid>


        </Grid>
        <Button Command="{Binding ToggleTunerCommand}" 
        Width="150" Height="40" 
        Foreground="White" FontWeight="Bold" FontSize="16"
        VerticalAlignment="Bottom" Margin="20">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="#39FF14"/>
                    <Setter Property="Content" Value="УВІМКНУТИ"/>

                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRecording}" Value="True">
                            <Setter Property="Background" Value="red"/>
                            <Setter Property="Content" Value="ВИМКНУТИ"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>

            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</UserControl>
