<UserControl x:Class="WPF_Project_1.View.UserControl.ClearableTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPF_Project_1.View.UserControl"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="300">
    <Grid Background="White">
        <TextBox Name="txtText" Grid.Row="1"  VerticalContentAlignment="Center"  
                 Background="Transparent" TextChanged="txtText_TextChanged"/>
        <TextBlock Name="tbPlaceHolder" Text="hello there" VerticalAlignment="center" Margin="5,0,60,0" Foreground="Gray" 
                   Panel.ZIndex="-1" />
        <Button Name="btnClear" HorizontalAlignment="Right" Width="40px" Background="Transparent" Content="X" Foreground="LightGray" BorderThickness="0"
                Click="Button_Click"/>
        
    </Grid>
</UserControl>
